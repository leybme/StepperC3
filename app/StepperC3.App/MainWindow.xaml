<Window x:Class="StepperC3.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:StepperC3.App.ViewModels"
        xmlns:conv="clr-namespace:StepperC3.App.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="1050" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NegatedBoolToVisibilityConverter x:Key="NegBoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Task List" Command="{Binding NewTaskListCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenTaskListCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveTaskListCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveTaskListAsCommand}" />
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Band="0" BandIndex="0">
                <Button Command="{Binding NewTaskListCommand}" ToolTip="New Task List" Content="📄 New" />
                <Button Command="{Binding OpenTaskListCommand}" ToolTip="Open Task List" Content="📂 Open" />
                <Button Command="{Binding SaveTaskListCommand}" ToolTip="Save Task List" Content="💾 Save" />
                <Separator />
                <Button Command="{Binding RunCommand}" ToolTip="Run task list" Content="▶ Run"
                        Foreground="Green" FontWeight="Bold" />
                <Button Command="{Binding StopCommand}" ToolTip="Stop execution" Content="⏹ Stop"
                        Foreground="Red" />
            </ToolBar>
        </ToolBarTray>

        <!-- ═══ Status Bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} steps ({1} enabled)">
                            <Binding Path="Steps.Count" />
                            <Binding Path="EnabledStepCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <ProgressBar Height="16" Minimum="0"
                             Maximum="{Binding ProgressMax}"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main Content ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Left Panel: Step Palette & Add ═══ -->
            <DockPanel Grid.Column="0">
                <GroupBox Header="Add Step" DockPanel.Dock="Top" Margin="4">
                    <StackPanel Margin="4">
                        <TextBlock Text="Step Type:" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Border x:Name="PaletteDrop"
                                BorderBrush="OrangeRed" BorderThickness="2" CornerRadius="3"
                                Visibility="Collapsed" Margin="0,0,0,2" Padding="4,2">
                            <TextBlock Text="🗑 Drop here to remove" Foreground="OrangeRed"
                                       FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                        <ListBox x:Name="PaletteListBox"
                                 ItemsSource="{Binding AvailableStepTypes}"
                                 SelectedItem="{Binding SelectedStepType}"
                                 AllowDrop="True"
                                 Height="Auto" MaxHeight="420"
                                 Margin="0,0,0,8"
                                 Background="#F0F0F0"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonDown="PaletteListBox_PreviewMouseLeftButtonDown"
                                 DragOver="PaletteListBox_DragOver"
                                 DragLeave="PaletteListBox_DragLeave"
                                 Drop="PaletteListBox_Drop">

                            <!-- Same custom item container as task list: white border when selected -->
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin"  Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Sel"
                                                        BorderThickness="2" CornerRadius="5"
                                                        BorderBrush="Transparent"
                                                        Background="Transparent"
                                                        Margin="2,1">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Sel" Property="BorderBrush" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <!-- Micro:bit coloured block with inline Motor ID + primary value -->
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,4"
                                            Background="{Binding CategoryBrush}">
                                        <DockPanel LastChildFill="True">

                                            <!-- Drag handle -->
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="⣿" Foreground="White" Opacity="0.55"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Cursor="SizeAll" Margin="0,0,5,0"/>

                                            <!-- Right: Motor ID + primary value fields -->
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">

                                                <!-- Motor ID -->
                                                <TextBlock Text="M:" Foreground="White" FontSize="10"
                                                           Opacity="0.85" VerticalAlignment="Center"
                                                           Margin="0,0,2,0"
                                                           Visibility="{Binding HasMotorId, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Text="{Binding EditMotorId, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="26" Height="20" FontSize="10" Padding="2,1"
                                                         Margin="0,0,6,0" VerticalAlignment="Center"
                                                         Visibility="{Binding HasMotorId, Converter={StaticResource BoolToVis}}"
                                                         PreviewMouseLeftButtonDown="PaletteField_PreviewMouseLeftButtonDown"/>

                                                <!-- Primary value -->
                                                <TextBlock Text="{Binding PrimaryValueLabel}" Foreground="White"
                                                           FontSize="10" Opacity="0.85"
                                                           VerticalAlignment="Center" Margin="0,0,2,0"
                                                           Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text=":" Foreground="White" FontSize="10"
                                                           VerticalAlignment="Center" Margin="0,0,2,0"
                                                           Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Text="{Binding EditPrimaryValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="52" Height="20" FontSize="10" Padding="2,1"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"
                                                         PreviewMouseLeftButtonDown="PaletteField_PreviewMouseLeftButtonDown"/>
                                            </StackPanel>

                                            <!-- Step name -->
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Command="{Binding AddStepCommand}" Content="➕ Add Step"
                                Padding="8,4" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </GroupBox>

                <!-- Connection Panel -->
                <GroupBox Header="Connection" Margin="4">
                    <StackPanel Margin="4">
                        <DockPanel Margin="0,0,0,4">
                            <Button Content="🔄" DockPanel.Dock="Right" Width="28" Margin="4,0,0,0"
                                    Command="{Binding RefreshPortsCommand}" ToolTip="Refresh ports" />
                            <ComboBox ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SelectedPort}"
                                      IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🔌 Connect" Command="{Binding ConnectCommand}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="🔓 Disconnect" Command="{Binding DisconnectCommand}"
                                    Padding="8,4" />
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⚫ Disconnected" />
                                    <Setter Property="Foreground" Value="Gray" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="🟢 Connected" />
                                            <Setter Property="Foreground" Value="Green" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

            <!-- ═══ Center Panel: Task List Steps ═══ -->
            <DockPanel Grid.Column="2">
                <!-- Task List Header -->
                <GroupBox Header="Task List" DockPanel.Dock="Top" Margin="4,4,4,0">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,8,4" />
                        <TextBox Grid.Column="1" Text="{Binding TaskListName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Text="Description:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding TaskListDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <!-- Step List Actions -->
                <ToolBarTray DockPanel.Dock="Top" Margin="4,2,4,0">
                    <ToolBar Band="0" BandIndex="0">
                        <Button Command="{Binding RemoveStepCommand}" Content="🗑 Remove" ToolTip="Remove selected step" />
                        <Button Command="{Binding DuplicateStepCommand}" Content="📋 Duplicate" ToolTip="Duplicate selected step" />
                        <Separator />
                        <Button Command="{Binding MoveStepUpCommand}" Content="⬆ Up" ToolTip="Move step up" />
                        <Button Command="{Binding MoveStepDownCommand}" Content="⬇ Down" ToolTip="Move step down" />
                        <Separator />
                        <Button Command="{Binding ToggleStepCommand}" Content="⏯ Toggle" ToolTip="Enable/Disable selected step" />
                        <Separator />
                        <Button Command="{Binding ClearStepsCommand}" Content="🧹 Clear All" ToolTip="Remove all steps" />
                    </ToolBar>
                </ToolBarTray>

                <!-- Step List -->
                <ListBox Margin="4" ItemsSource="{Binding Steps}"
                         SelectedItem="{Binding SelectedStep}"
                         SelectedIndex="{Binding SelectedStepIndex}"
                         AllowDrop="True"
                         x:Name="StepListBox"
                         Background="#F0F0F0"
                         BorderThickness="1"
                         PreviewMouseLeftButtonDown="StepListBox_PreviewMouseLeftButtonDown"
                         Drop="StepListBox_Drop"
                         DragOver="StepListBox_DragOver"
                         DragLeave="StepListBox_DragLeave"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <!-- Remove default selection highlight; use white border instead -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="SelectionBorder"
                                                BorderThickness="2" CornerRadius="7"
                                                BorderBrush="Transparent"
                                                Background="Transparent"
                                                Margin="2,2">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SelectionBorder"
                                                        Property="BorderBrush" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Micro:bit-style coloured block -->
                            <Border CornerRadius="5" ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{Binding CategoryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <!-- Single row — description swaps to edit fields in-place -->
                                <DockPanel Margin="6,5,6,5" LastChildFill="True">

                                    <!-- Drag handle -->
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="⣿" Foreground="White" Opacity="0.55"
                                               FontSize="13" VerticalAlignment="Center"
                                               Cursor="SizeAll" Margin="0,0,6,0"/>

                                    <!-- Right-side action buttons -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center">

                                        <!-- Type label + Edit button (normal mode) -->
                                        <TextBlock Text="{Binding Type}" Foreground="White"
                                                   Opacity="0.65" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Visibility="{Binding IsEditing, Converter={StaticResource NegBoolToVis}}"/>
                                        <Button Content="✏" Width="22" Height="22" Padding="0"
                                                FontSize="11" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="White"
                                                Visibility="{Binding IsEditing, Converter={StaticResource NegBoolToVis}}"
                                                Command="{Binding BeginEditCommand}"/>

                                        <!-- Commit / Cancel (edit mode) -->
                                        <Button Content="✓" Width="24" Height="22" Padding="0"
                                                FontSize="13" FontWeight="Bold" Cursor="Hand"
                                                Background="#3DFFFFFF" BorderThickness="0"
                                                Foreground="White"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding CommitEditCommand}"/>
                                        <Button Content="✗" Width="24" Height="22" Padding="0"
                                                FontSize="13" Cursor="Hand"
                                                Background="#3DFFFFFF" BorderThickness="0"
                                                Foreground="White"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding CancelEditCommand}"/>
                                    </StackPanel>

                                    <!-- Normal mode: description text -->
                                    <TextBlock Text="{Binding Description}" Foreground="White"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="12"
                                               Visibility="{Binding IsEditing, Converter={StaticResource NegBoolToVis}}"/>

                                    <!-- Edit mode: inline fields (same row, no expand) -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">

                                        <!-- Motor ID -->
                                        <TextBlock Text="Motor:" Foreground="White" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Visibility="{Binding ShowMotorId, Converter={StaticResource BoolToVis}}"/>
                                        <TextBox Text="{Binding EditMotorId, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="32" Height="22" FontSize="11" Padding="2,1"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Visibility="{Binding ShowMotorId, Converter={StaticResource BoolToVis}}"
                                                 PreviewKeyDown="EditTextBox_PreviewKeyDown"/>

                                        <!-- Primary value label -->
                                        <TextBlock Text="{Binding PrimaryValueLabel}" Foreground="White"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text=":" Foreground="White" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"/>
                                        <TextBox Text="{Binding PrimaryValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="80" Height="22" FontSize="11" Padding="2,1"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Visibility="{Binding HasPrimaryValue, Converter={StaticResource BoolToVis}}"
                                                 PreviewKeyDown="EditTextBox_PreviewKeyDown"/>

                                        <!-- Secondary value (RunCommand args) -->
                                        <TextBlock Text="{Binding SecondaryValueLabel}" Foreground="White"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Visibility="{Binding HasSecondaryValue, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text=":" Foreground="White" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,3,0"
                                                   Visibility="{Binding HasSecondaryValue, Converter={StaticResource BoolToVis}}"/>
                                        <TextBox Text="{Binding SecondaryValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="120" Height="22" FontSize="11" Padding="2,1"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding HasSecondaryValue, Converter={StaticResource BoolToVis}}"
                                                 PreviewKeyDown="EditTextBox_PreviewKeyDown"/>
                                    </StackPanel>

                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" />

            <!-- ═══ Right Panel: Properties & Log ═══ -->
            <DockPanel Grid.Column="4">
                <!-- Step Properties -->
                <GroupBox Header="Step Properties" DockPanel.Dock="Top" Margin="4,4,4,0"
                          Visibility="{Binding SelectedStep, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="4" DataContext="{Binding SelectedStep}">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Type:" FontWeight="SemiBold" Width="70" />
                            <TextBlock Text="{Binding Type}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Motor ID:" FontWeight="SemiBold" Width="70" />
                            <TextBox Text="{Binding MotorId, UpdateSourceTrigger=PropertyChanged}" Width="50"
                                     HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Enabled:" FontWeight="SemiBold" Width="70" />
                            <CheckBox IsChecked="{Binding IsEnabled}" />
                        </DockPanel>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                   Foreground="#555" Margin="0,4,0,0" />
                    </StackPanel>
                </GroupBox>

                <!-- Log Output -->
                <GroupBox Header="Log" Margin="4">
                    <ListBox ItemsSource="{Binding LogMessages}" x:Name="LogListBox"
                             FontFamily="Consolas" FontSize="11"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>

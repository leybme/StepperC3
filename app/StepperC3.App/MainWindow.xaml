<Window x:Class="StepperC3.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:StepperC3.App.ViewModels"
        xmlns:conv="clr-namespace:StepperC3.App.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="1050" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Task List" Command="{Binding NewTaskListCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenTaskListCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveTaskListCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveTaskListAsCommand}" />
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══ -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Band="0" BandIndex="0">
                <Button Command="{Binding NewTaskListCommand}" ToolTip="New Task List" Content="📄 New" />
                <Button Command="{Binding OpenTaskListCommand}" ToolTip="Open Task List" Content="📂 Open" />
                <Button Command="{Binding SaveTaskListCommand}" ToolTip="Save Task List" Content="💾 Save" />
                <Separator />
                <Button Command="{Binding RunCommand}" ToolTip="Run task list" Content="▶ Run"
                        Foreground="Green" FontWeight="Bold" />
                <Button Command="{Binding StopCommand}" ToolTip="Stop execution" Content="⏹ Stop"
                        Foreground="Red" />
            </ToolBar>
        </ToolBarTray>

        <!-- ═══ Status Bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} steps ({1} enabled)">
                            <Binding Path="Steps.Count" />
                            <Binding Path="Steps.Count" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <ProgressBar Height="16" Minimum="0"
                             Maximum="{Binding ProgressMax}"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Main Content ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="280" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Left Panel: Step Palette & Add ═══ -->
            <DockPanel Grid.Column="0">
                <GroupBox Header="Add Step" DockPanel.Dock="Top" Margin="4">
                    <StackPanel Margin="4">
                        <TextBlock Text="Step Type:" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ListBox ItemsSource="{Binding AvailableStepTypes}"
                                 SelectedItem="{Binding SelectedStepType}"
                                 Height="200" Margin="0,0,0,8">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                       Foreground="#0078D7" Margin="0,4,0,2" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding Description}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Motor ID:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Text="{Binding NewStepMotorId, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" HorizontalAlignment="Left" />
                        </DockPanel>

                        <Button Command="{Binding AddStepCommand}" Content="➕ Add Step"
                                Padding="8,4" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </GroupBox>

                <!-- Connection Panel -->
                <GroupBox Header="Connection" Margin="4">
                    <StackPanel Margin="4">
                        <DockPanel Margin="0,0,0,4">
                            <Button Content="🔄" DockPanel.Dock="Right" Width="28" Margin="4,0,0,0"
                                    Command="{Binding RefreshPortsCommand}" ToolTip="Refresh ports" />
                            <ComboBox ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SelectedPort}"
                                      IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🔌 Connect" Command="{Binding ConnectCommand}"
                                    Padding="8,4" Margin="0,0,4,0" />
                            <Button Content="🔓 Disconnect" Command="{Binding DisconnectCommand}"
                                    Padding="8,4" />
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⚫ Disconnected" />
                                    <Setter Property="Foreground" Value="Gray" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="🟢 Connected" />
                                            <Setter Property="Foreground" Value="Green" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

            <!-- ═══ Center Panel: Task List Steps ═══ -->
            <DockPanel Grid.Column="2">
                <!-- Task List Header -->
                <GroupBox Header="Task List" DockPanel.Dock="Top" Margin="4,4,4,0">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,8,4" />
                        <TextBox Grid.Column="1" Text="{Binding TaskListName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Text="Description:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding TaskListDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <!-- Step List Actions -->
                <ToolBarTray DockPanel.Dock="Top" Margin="4,2,4,0">
                    <ToolBar Band="0" BandIndex="0">
                        <Button Command="{Binding RemoveStepCommand}" Content="🗑 Remove" ToolTip="Remove selected step" />
                        <Button Command="{Binding DuplicateStepCommand}" Content="📋 Duplicate" ToolTip="Duplicate selected step" />
                        <Separator />
                        <Button Command="{Binding MoveStepUpCommand}" Content="⬆ Up" ToolTip="Move step up" />
                        <Button Command="{Binding MoveStepDownCommand}" Content="⬇ Down" ToolTip="Move step down" />
                        <Separator />
                        <Button Command="{Binding ToggleStepCommand}" Content="⏯ Toggle" ToolTip="Enable/Disable selected step" />
                        <Separator />
                        <Button Command="{Binding ClearStepsCommand}" Content="🧹 Clear All" ToolTip="Remove all steps" />
                    </ToolBar>
                </ToolBarTray>

                <!-- Step List -->
                <ListBox Margin="4" ItemsSource="{Binding Steps}"
                         SelectedItem="{Binding SelectedStep}"
                         SelectedIndex="{Binding SelectedStepIndex}"
                         AllowDrop="True"
                         x:Name="StepListBox"
                         PreviewMouseLeftButtonDown="StepListBox_PreviewMouseLeftButtonDown"
                         Drop="StepListBox_Drop"
                         DragOver="StepListBox_DragOver"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" CornerRadius="3" Margin="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Background" Value="#20FF0000" />
                                                <Setter Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0"
                                               FontFamily="Segoe UI Symbol" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✓" />
                                                <Setter Property="Foreground" Value="Green" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Text" Value="✗" />
                                                        <Setter Property="Foreground" Value="Red" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Type}" Foreground="Gray"
                                               FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding Description}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" />

            <!-- ═══ Right Panel: Properties & Log ═══ -->
            <DockPanel Grid.Column="4">
                <!-- Step Properties -->
                <GroupBox Header="Step Properties" DockPanel.Dock="Top" Margin="4,4,4,0"
                          Visibility="{Binding SelectedStep, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="4" DataContext="{Binding SelectedStep}">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Type:" FontWeight="SemiBold" Width="70" />
                            <TextBlock Text="{Binding Type}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Motor ID:" FontWeight="SemiBold" Width="70" />
                            <TextBox Text="{Binding MotorId, UpdateSourceTrigger=PropertyChanged}" Width="50"
                                     HorizontalAlignment="Left" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Enabled:" FontWeight="SemiBold" Width="70" />
                            <CheckBox IsChecked="{Binding IsEnabled}" />
                        </DockPanel>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                   Foreground="#555" Margin="0,4,0,0" />
                    </StackPanel>
                </GroupBox>

                <!-- Log Output -->
                <GroupBox Header="Log" Margin="4">
                    <ListBox ItemsSource="{Binding LogMessages}" x:Name="LogListBox"
                             FontFamily="Consolas" FontSize="11"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
